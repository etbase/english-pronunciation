#!/usr/bin/env bash
# 安全掃描（push 前的第二層防護）：pre-commit 已經擋過一次，這裡在真正推上 GitHub 之前再檢查一次，
# 避免因為某次 commit 用了 --no-verify、或是舊的 commit 裡本來就藏著機密，一路漏到這裡才被擋下來。
#
# 如果確定是誤判，可用 `git push --no-verify` 強制跳過，但請先確認真的沒有洩漏機密。

RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m'

ZERO_SHA='0000000000000000000000000000000000000000'

CONTENT_PATTERNS=(
  'AIza[0-9A-Za-z_-]{35,}'
  'AKIA[0-9A-Z]{16,}'
  'sk_live_[0-9A-Za-z]{20,}'
  'sk_test_[0-9A-Za-z]{20,}'
  '\-\-\-\-\-BEGIN (RSA |EC )?PRIVATE KEY\-\-\-\-\-'
  '"private_key": *"-----BEGIN'
)

TMP_FLAG=$(mktemp)
trap 'rm -f "$TMP_FLAG"' EXIT

while read -r local_ref local_sha remote_ref remote_sha; do
  [ -z "$local_sha" ] && continue
  [ "$local_sha" = "$ZERO_SHA" ] && continue

  if [ "$remote_sha" = "$ZERO_SHA" ]; then
    range="$local_sha"
  else
    range="$remote_sha..$local_sha"
  fi

  for pattern in "${CONTENT_PATTERNS[@]}"; do
    if git log -p "$range" 2>/dev/null | grep -Eq "$pattern"; then
      echo -e "${RED}✗ 擋下 push：即將推送的內容裡疑似含有機密金鑼（符合格式：${pattern}）。${NC}"
      echo "x" >> "$TMP_FLAG"
    fi
  done
done

if [ -s "$TMP_FLAG" ]; then
  echo -e "${YELLOW}請先移除機密內容並改成環境變數（.env，已被 .gitignore 排除）。如果確定是誤判，可用 git push --no-verify 強制跳過。${NC}"
  exit 1
fi

exit 0
